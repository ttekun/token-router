[
  {
    "name": "query pass-through locates token expiration",
    "fixture": "fixtures/query_token_expiration.py",
    "mode": "heavy_code",
    "query": "token expiration",
    "prompt_contains": [
      "[User Query]: token expiration",
      "def token_expiration_seconds(user):",
      "session_token_expires_at"
    ],
    "mock_response": {
      "targets": [
        {
          "start_line": 8,
          "end_line": 11,
          "reason": "token expiration logic"
        }
      ]
    },
    "expected_contains_lines": [8, 9, 10, 11],
    "expected_output_contains": ["token expiration logic"]
  },
  {
    "name": "overlap merge and output cap",
    "fixture": "fixtures/overlap_lines.txt",
    "mode": "heavy_code",
    "env": {
      "ROUTER_MAX_OUTPUT_LINES": "5"
    },
    "mock_response": {
      "targets": [
        {
          "start_line": 10,
          "end_line": 14,
          "reason": "first"
        },
        {
          "start_line": 12,
          "end_line": 20,
          "reason": "second"
        },
        {
          "start_line": "bad",
          "end_line": 30,
          "reason": "malformed"
        }
      ]
    },
    "expected_contains_lines": [10, 11, 12, 13, 14],
    "expected_output_contains": ["first; second [truncated by ROUTER_MAX_OUTPUT_LINES]"]
  },
  {
